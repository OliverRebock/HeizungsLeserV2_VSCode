# .env.example für Heizungsleser V2

# Allgemeine Projekt-Einstellungen
PROJECT_NAME="Heizungsleser V2"
ENVIRONMENT=local

# PostgreSQL Datenbank
POSTGRES_USER=heitleser_user
POSTGRES_PASSWORD=heitleser_pass
POSTGRES_DB=heitleser_db
POSTGRES_HOST=heizungsleser-v2-postgres
POSTGRES_PORT=5432

# Backend API
API_V1_STR=/api/v1
SECRET_KEY=A_VERY_SECRET_KEY_REPLACE_ME
ACCESS_TOKEN_EXPIRE_MINUTES=11520 # 8 Tage

# InfluxDB 3 (Bestandssystem)
INFLUXDB_V3_HOST=http://localhost:8086
INFLUXDB_V3_TOKEN=TOKEN_HERE
INFLUXDB_V3_ORG=ORG_HERE
# INFLUXDB_V3_ADMIN_TOKEN=... # optional für autom. DB-Anlage

# Erster Admin (Seed)
FIRST_SUPERUSER=admin@example.com
FIRST_SUPERUSER_PASSWORD=adminpass

# OpenAI (AI-Analyse Beta)
OPENAI_API_KEY=sk-proj-YOUR_KEY_HERE
OPENAI_MODEL_PRIMARY=gpt-4o
OPENAI_TIMEOUT_SECONDS=60
OPENAI_ANALYSIS_ENABLED=true
