# .env.example für Heizungsleser V2
# Allgemeine Projekt-Einstellungen
PROJECT_NAME="Heizungsleser V2"
ENVIRONMENT=local

# PostgreSQL Datenbank (Wird in Docker Compose genutzt)
POSTGRES_USER=heitleser_user
POSTGRES_PASSWORD=REPLACE_WITH_SECURE_PASSWORD
POSTGRES_DB=heitleser_db
POSTGRES_HOST=heizungsleser-v2-postgres
POSTGRES_PORT=5432

# Backend API
API_V1_STR=/api/v1
SECRET_KEY=REPLACE_WITH_GENERATED_SECURE_SECRET_KEY
ACCESS_TOKEN_EXPIRE_MINUTES=11520 # 8 Tage

# InfluxDB (Zielsystem für Zeitreihendaten)
# InfluxDB 2.x (Empfohlenes Standard-System)
INFLUXDB_URL=http://localhost:8086
INFLUXDB_TOKEN=REPLACE_WITH_INFLUX_TOKEN
INFLUXDB_ORG=deine-org
INFLUXDB_BUCKET=dein-bucket
# INFLUXDB_ADMIN_TOKEN=REPLACE_WITH_INFLUX_ADMIN_TOKEN # Optional für automatische Bucket-Anlage

# InfluxDB 3 (Legacy / Experimentell)
# INFLUXDB_V3_HOST=us-east-1-1.aws.cloud2.influxdata.com
# INFLUXDB_V3_TOKEN=dein-v3-token
# INFLUXDB_V3_ORG=deine-org
# INFLUXDB_V3_DATABASE=deine-db

# Erster Admin (Initialer Superuser bei DB-Setup)
FIRST_SUPERUSER=admin@example.com
FIRST_SUPERUSER_PASSWORD=REPLACE_WITH_SECURE_PASSWORD

# OpenAI Integration (KI-Analyse & Deep Analysis)
OPENAI_API_KEY=sk-proj-REPLACE_WITH_YOUR_OPENAI_KEY
OPENAI_MODEL_PRIMARY=gpt-5.3
OPENAI_TIMEOUT_SECONDS=60
OPENAI_ANALYSIS_ENABLED=true
